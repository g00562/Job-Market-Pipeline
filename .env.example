# ==========================================
# Database Configuration
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_market_db
DB_USER=postgres
DB_PASSWORD=your_secure_password

# ==========================================
# Google Sheets Configuration
# ==========================================
GOOGLE_SHEETS_CREDS=credentials/google_sheets_creds.json
GOOGLE_SHEET_ID=1PBwphUOosT4XICocl9iQmeqqntLGcwNnMom_-hrg4Ro

# ==========================================
# API Keys
# ==========================================
RAPIDAPI_KEY=your_rapidapi_key_here

# ==========================================
# Application Configuration
# ==========================================
LOG_LEVEL=INFO
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
CONNECTION_POOL_SIZE=5
DB_TIMEOUT=30

# ==========================================
# Scraper Configuration
# ==========================================
SCRAPER_TIMEOUT=30
SCRAPER_DELAY_MIN=2
SCRAPER_DELAY_MAX=5
NAUKRI_PAGES_PER_LOCATION=3
LINKEDIN_PAGES_PER_LOCATION=3
INDEED_PAGES_PER_LOCATION=2

# ==========================================
# Airflow Configuration (Optional)
# ==========================================
AIRFLOW_HOME=./airflow
AIRFLOW_DAG_FOLDER=./airflow/dags


